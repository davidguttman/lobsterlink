{
  "manifest_version": 3,
  "name": "Vipsee",
  "version": "0.1.0",
  "description": "Remote browser tab viewing and control via WebRTC",
  "permissions": [
    "tabCapture",
    "tabs",
    "debugger",
    "activeTab",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vipsee"
  },
  "icons": {},
  "web_accessible_resources": []
}
