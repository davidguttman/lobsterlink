{
  "manifest_version": 3,
  "name": "LobsterLink",
  "version": "4.20.0.1",
  "description": "Remote browser tab viewing and control via WebRTC",
  "permissions": [
    "tabs",
    "debugger",
    "activeTab",
    "offscreen",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LobsterLink"
  },
  "icons": {},
  "web_accessible_resources": []
}
